{
  "name": "gkeep-clone-backend-nodejs-fastify",
  "version": "0.1.0",
  "description": "A note-taking back-end application personal project. Inspired by Google Keep.",
  "author": {
    "name": "Syahda Romansyah",
    "email": "codewithsyahda@gmail.com"
  },
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "tsx --tsconfig ./tsconfig.build.json src/app.ts",
    "dev:w": "tsx watch --tsconfig ./tsconfig.build.json src/app.ts",
    "dev:e2e": "tsx --tsconfig ./tsconfig.node.json test/e2e/e2eHelperApp.ts",
    "build": "rimraf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "cross-env NODE_ENV=production node dist/app.js",
    "start:e2e": "cross-env NODE_ENV=ci node dist/app.js",
    "lint": "eslint .",
    "format:c": "prettier -c .",
    "format:w": "prettier -w .",
    "test:ci": "vitest run --coverage",
    "test:w": "vitest --coverage",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.build.json --noEmit",
    "prepare": "husky"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "4.1.7",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.5",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "undici": "^8.3.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tiptap/core": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.21.0",
    "typebox": "^1.1.38"
  }
}
